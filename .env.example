# Copy to .env.local (per-app, or root — see README) and fill in real values.
# Never commit .env.local — it's gitignored by default in this repo.

# --- Supabase (Sprint 1) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never prefix with NEXT_PUBLIC_ — this bypasses every RLS policy.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 JWT secret (Dashboard -> Settings -> API -> JWT Settings). Signs guest
# session tokens so PostgREST/RLS can verify them like a normal Supabase Auth token (§14.5).
SUPABASE_JWT_SECRET=
# Pooled connection (pgbouncer, transaction mode) — used by the app at runtime.
DATABASE_URL=
# Session-mode pooler — used for running migrations (supabase db push).
DIRECT_URL=

# --- staff-pwa only (Phase 2, §7.2) ---
# Deployed guest-web URL, used to build copyable /register/[token] pre-registration links.
NEXT_PUBLIC_GUEST_WEB_URL=

# --- Paystack (Sprint 4) ---
# sk_test_... / sk_live_... — also used to verify webhook signatures (Paystack
# signs with the integration's secret key itself, not a separate webhook secret).
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Unused — kept for now, see the PAYSTACK_SECRET_KEY comment above.
PAYSTACK_WEBHOOK_SECRET=

# --- Firebase Cloud Messaging — push notifications only (Sprint 5) ---
FCM_SERVER_KEY=
NEXT_PUBLIC_FCM_VAPID_KEY=

# --- Hubtel SMS (Sprint 5) ---
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=

# --- WhatsApp Business API via Twilio (Sprint 5) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
