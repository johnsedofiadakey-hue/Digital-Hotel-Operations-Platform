# Copy to .env.local (per-app, or root — see README) and fill in real values.
# Never commit .env.local — it's gitignored by default in this repo.

# --- Supabase (Sprint 1) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never prefix with NEXT_PUBLIC_ — this bypasses every RLS policy.
SUPABASE_SERVICE_ROLE_KEY=
# Pooled connection (pgbouncer, transaction mode) — used by the app at runtime.
DATABASE_URL=
# Session-mode pooler — used for running migrations (supabase db push).
DIRECT_URL=

# --- Paystack (Sprint 4) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Firebase Cloud Messaging — push notifications only (Sprint 5) ---
FCM_SERVER_KEY=
NEXT_PUBLIC_FCM_VAPID_KEY=

# --- Hubtel SMS (Sprint 5) ---
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=

# --- WhatsApp Business API via Twilio (Sprint 5) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
